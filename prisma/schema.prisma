generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundPhase {
  DRAFT
  REFLECTION
  RELAY
  PAUSED
  COMPLETE
}

enum TeamStatus {
  REGISTERED
  READY
  CODING
  SUBMITTED
  SCORED
}

model RoundControl {
  id               String     @id
  registrationOpen Boolean    @default(true)
  phase            RoundPhase @default(DRAFT)
  previousPhase    RoundPhase?
  phaseStartedAt   DateTime?
  pausedElapsedMs  Int?
  reflectionMs     Int        @default(300000)
  relaySliceMs     Int        @default(120000)
  totalRelaySlices Int        @default(12)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Team {
  id            String       @id @default(cuid())
  teamCode      String       @unique
  editTokenHash String
  name          String
  station       String
  status        TeamStatus   @default(REGISTERED)
  locked        Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  submittedAt   DateTime?
  members       TeamMember[]
  score         Score?

  @@index([createdAt])
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  name       String
  relayOrder Int
  createdAt  DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, relayOrder])
}

model Score {
  id          String   @id @default(cuid())
  teamId      String   @unique
  correction  Int      @default(0)
  edgeCases   Int      @default(0)
  complexity  Int      @default(0)
  readability Int      @default(0)
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}
