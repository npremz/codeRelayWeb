generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundPhase {
  DRAFT
  REFLECTION
  RELAY
  PAUSED
  COMPLETE
}

enum TeamStatus {
  REGISTERED
  READY
  CODING
  SUBMITTED
  SCORED
}

enum TvDisplayMode {
  LIVE
  BRIEF
  LEADERBOARD
  REGISTRATION_QR
}

model Round {
  id                  String       @id @default(cuid())
  sequence            Int          @unique
  name                String
  isCurrent           Boolean      @default(false)
  subjectId           String?
  subjectTitle        String?
  subjectFileName     String?
  subjectBrief        String?
  subjectFunctionName String?
  registrationOpen    Boolean      @default(true)
  phase               RoundPhase   @default(DRAFT)
  previousPhase       RoundPhase?
  phaseStartedAt      DateTime?
  pausedElapsedMs     Int?
  reflectionMs        Int          @default(300000)
  relaySliceMs        Int          @default(120000)
  totalRelaySlices    Int          @default(12)
  tvDisplayMode       TvDisplayMode @default(LIVE)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  entries             RoundEntry[]

  @@index([isCurrent])
  @@index([createdAt])
}

model Team {
  id            String       @id @default(cuid())
  teamCode      String       @unique
  editTokenHash String
  name          String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  members       TeamMember[]
  entries       RoundEntry[]

  @@index([createdAt])
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId     String
  name       String
  relayOrder Int
  createdAt  DateTime @default(now())
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, relayOrder])
}

model RoundEntry {
  id          String      @id @default(cuid())
  roundId     String
  teamId      String
  station     String
  status      TeamStatus  @default(REGISTERED)
  locked      Boolean     @default(false)
  submittedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  round       Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  score       RoundScore?

  @@unique([roundId, teamId])
  @@unique([roundId, station])
  @@index([roundId, createdAt])
}

model RoundScore {
  id           String     @id @default(cuid())
  roundEntryId String     @unique
  correction   Int        @default(0)
  edgeCases    Int        @default(0)
  complexity   Int        @default(0)
  readability  Int        @default(0)
  notes        String     @default("")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  roundEntry   RoundEntry @relation(fields: [roundEntryId], references: [id], onDelete: Cascade)
}
