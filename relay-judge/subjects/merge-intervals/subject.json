{
  "id": "merge-intervals",
  "title": "Merge Intervals",
  "prototype": "def merge_intervals(intervals):",
  "difficulty": "medium",
  "description": "Fusionne tous les intervalles de `intervals` qui se chevauchent ou se touchent, puis retourne une liste finale triée et normalisée.",
  "parameters": [
    {
      "name": "intervals",
      "type": "list[list[int]]",
      "description": "Liste d'intervalles `[start, end]` à fusionner."
    }
  ],
  "returns": {
    "type": "list[list[int]]",
    "description": "La liste triée des intervalles fusionnés sans recouvrement."
  },
  "constraints": [
    "1 <= intervals.length <= 10^4",
    "intervals[i].length == 2",
    "0 <= start <= end <= 10^4"
  ],
  "examples": [
    {
      "title": "Exemple 1",
      "input": {
        "intervals": [[1, 3], [2, 6], [8, 10], [15, 18]]
      },
      "output": [[1, 6], [8, 10], [15, 18]]
    },
    {
      "title": "Exemple 2",
      "input": {
        "intervals": [[1, 4], [4, 5]]
      },
      "output": [[1, 5]],
      "explanation": "Deux intervalles qui se touchent doivent être fusionnés."
    },
    {
      "title": "Exemple 3",
      "input": {
        "intervals": [[6, 8], [1, 9], [2, 4], [4, 7]]
      },
      "output": [[1, 9]]
    }
  ],
  "file_name": "merge_intervals.py",
  "function_name": "merge_intervals",
  "checker": "intervals_exact",
  "time_limit_ms": 1500,
  "tests": [
    {
      "name": "simple_overlap",
      "group": "core",
      "args": [[[1, 3], [2, 6], [8, 10], [15, 18]]],
      "expected": [[1, 6], [8, 10], [15, 18]]
    },
    {
      "name": "touching_intervals",
      "group": "core",
      "args": [[[1, 4], [4, 5]]],
      "expected": [[1, 5]]
    },
    {
      "name": "already_sorted_with_gaps",
      "group": "edge",
      "args": [[[1, 2], [5, 7], [9, 12]]],
      "expected": [[1, 2], [5, 7], [9, 12]]
    },
    {
      "name": "unsorted_nested",
      "group": "edge",
      "args": [[[6, 8], [1, 9], [2, 4], [4, 7]]],
      "expected": [[1, 9]]
    },
    {
      "name": "anti_hardcode_reverse_input",
      "group": "anti-hardcode",
      "args": [[[9, 10], [3, 5], [4, 8], [1, 2]]],
      "expected": [[1, 2], [3, 8], [9, 10]]
    },
    {
      "name": "perf_many_small_intervals",
      "group": "perf",
      "args": [[[0, 1], [1, 2], [2, 3], [3, 4], [10, 11], [11, 12], [12, 13], [20, 21], [30, 31], [31, 32], [32, 33], [33, 34], [34, 35], [100, 200]]],
      "expected": [[0, 4], [10, 13], [20, 21], [30, 35], [100, 200]]
    }
  ]
}
