{
  "id": "longest-substring-without-repeating-characters",
  "title": "Longest Substring Without Repeating Characters",
  "prototype": "def longest_substring_without_repeating_characters(s):",
  "difficulty": "medium",
  "description": "Retourne la longueur de la plus longue sous-chaîne de `s` qui ne contient aucun caractère répété. Une sous-chaîne est forcément contiguë.",
  "parameters": [
    {
      "name": "s",
      "type": "string",
      "description": "Chaîne d'entrée dans laquelle il faut chercher la plus longue fenêtre sans doublon."
    }
  ],
  "returns": {
    "type": "int",
    "description": "La longueur maximale d'une sous-chaîne contiguë sans répétition."
  },
  "constraints": [
    "0 <= s.length <= 5 * 10^4",
    "`s` peut contenir des lettres, chiffres, symboles ou espaces",
    "La sous-chaîne recherchée doit être contiguë"
  ],
  "examples": [
    {
      "title": "Exemple 1",
      "input": {
        "s": "abcabcbb"
      },
      "output": 3,
      "explanation": "La meilleure sous-chaîne est `abc`."
    },
    {
      "title": "Exemple 2",
      "input": {
        "s": "bbbbb"
      },
      "output": 1,
      "explanation": "La seule sous-chaîne valide maximale est `b`."
    },
    {
      "title": "Exemple 3",
      "input": {
        "s": "pwwkew"
      },
      "output": 3,
      "explanation": "`wke` est valide, mais `pwke` n'est pas contiguë."
    },
    {
      "title": "Exemple 4",
      "input": {
        "s": ""
      },
      "output": 0
    }
  ],
  "file_name": "longest_substring_without_repeating_characters.py",
  "function_name": "longest_substring_without_repeating_characters",
  "checker": "exact_int",
  "time_limit_ms": 1500,
  "tests": [
    {
      "name": "leetcode_example_1",
      "group": "core",
      "args": ["abcabcbb"],
      "expected": 3
    },
    {
      "name": "all_same",
      "group": "core",
      "args": ["bbbbb"],
      "expected": 1
    },
    {
      "name": "overlapping_window",
      "group": "edge",
      "args": ["pwwkew"],
      "expected": 3
    },
    {
      "name": "empty_string",
      "group": "edge",
      "args": [""],
      "expected": 0
    },
    {
      "name": "anti_hardcode_repeated_after_gap",
      "group": "anti-hardcode",
      "args": ["dvdf"],
      "expected": 3
    },
    {
      "name": "perf_unique_tail",
      "group": "perf",
      "args": ["abcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyzabcdefghijklmnopqrstuvwxyz"],
      "expected": 26
    }
  ]
}
