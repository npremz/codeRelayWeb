{
  "id": "valid-parentheses",
  "title": "Valid Parentheses",
  "prototype": "def valid_parentheses(s):",
  "difficulty": "easy",
  "description": "Retourne `true` si la chaîne `s` est correctement parenthésée. Chaque ouverture doit être fermée par le bon symbole et dans le bon ordre.",
  "parameters": [
    {
      "name": "s",
      "type": "string",
      "description": "Chaîne composée uniquement de parenthèses, crochets et accolades."
    }
  ],
  "returns": {
    "type": "bool",
    "description": "`true` si la chaîne est valide, sinon `false`."
  },
  "constraints": [
    "1 <= s.length <= 10^4",
    "`s` ne contient que `()[]{}`",
    "Aucune ouverture ne doit rester sans fermeture"
  ],
  "examples": [
    {
      "title": "Exemple 1",
      "input": {
        "s": "()[]{}"
      },
      "output": true
    },
    {
      "title": "Exemple 2",
      "input": {
        "s": "(]"
      },
      "output": false
    },
    {
      "title": "Exemple 3",
      "input": {
        "s": "([)]"
      },
      "output": false
    },
    {
      "title": "Exemple 4",
      "input": {
        "s": "{[()()]}"
      },
      "output": true
    }
  ],
  "file_name": "valid_parentheses.py",
  "function_name": "valid_parentheses",
  "checker": "exact_bool",
  "time_limit_ms": 1200,
  "tests": [
    {
      "name": "simple_valid",
      "group": "core",
      "args": ["()[]{}"],
      "expected": true
    },
    {
      "name": "simple_invalid",
      "group": "core",
      "args": ["(]"],
      "expected": false
    },
    {
      "name": "nested_valid",
      "group": "edge",
      "args": ["{[()()]}"],
      "expected": true
    },
    {
      "name": "wrong_order",
      "group": "edge",
      "args": ["([)]"],
      "expected": false
    },
    {
      "name": "unfinished_stack",
      "group": "edge",
      "args": ["(((()"],
      "expected": false
    },
    {
      "name": "anti_hardcode_mixed_valid",
      "group": "anti-hardcode",
      "args": ["([]{})[{}]"],
      "expected": true
    },
    {
      "name": "long_balanced",
      "group": "perf",
      "args": ["(((((((((((((((((((((((((((((((((((((((((((((((((())))))))))))))))))))))))))))))))))))))))))))))))))"],
      "expected": true
    }
  ]
}
