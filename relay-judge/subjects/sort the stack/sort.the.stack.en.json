{
  "title": "Sort the stack",
  "description": "Implement a function that print all the elements from the two stacks received as arguments in ascending order.",
  "parameters": [
    {
      "name": "stack1",
      "description": "The first stack."
    },
    {
      "name": "len stack1",
      "description": "The number of elements in the first stack."
    },
    {
      "name": "stack2",
      "description": "The second stack."
    },
    {
      "name": "len stack2",
      "description": "The number of elements in the second stack."
    }
  ],
  "returns": {
    "description": "Print the merged stack in ascending order."
  },
  "constraints": [
    "Have a lot of fun"
  ],
  "examples": [
    {
      "title": "Example 1",
      "input": {
        "stack1": [1, 3, 5],
        "len stack1": 3,
        "stack2": [2, 4, 6],
        "len stack2": 3
      },
      "output": [1, 2, 3, 4, 5, 6]
    },
    {
      "title": "Example 2",
      "input": {
        "stack1": [1, 9, 3],
        "len stack1": 3,
        "stack2": [4, 5, 6],
        "len stack2": 3
      },
      "output": [1, 3, 4, 5, 6, 9]
    },
    {
      "title": "Example 3",
      "input": {
        "stack1": [12, 4, 3],
        "len stack1": 3,
        "stack2": [6, 90, 8],
        "len stack2": 3
      },
      "output": [3, 4, 6, 8, 12, 90]
    },
    {
      "title": "Example 4",
      "input": {
        "stack1": [1, 2, 3, 6, 8, 12],
        "len stack1": 3,
        "stack2": [1, 2, 3],
        "len stack2": 3
      },
      "output": [1, 1, 2, 2, 3, 3, 6, 8, 12]
    }
  ]
}
