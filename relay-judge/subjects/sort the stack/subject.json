{
  "id": "sort-the-stack",
  "title": "Sort the stack",
  "prototype": "void sort_the_stack(int *stack1, int len_stack1, int *stack2, int len_stack2):",
  "difficulty": "easy",
  "description": "Implement a function that print all the elements from the two stacks received as arguments in ascending order.",
  "parameters": [
    {
      "name": "stack1",
      "type": "stack",
      "description": "The first stack."
    },
    {
      "name": "len stack1",
      "type": "int",
      "description": "The number of elements in the first stack."
    },
    {
      "name": "stack2",
      "type": "stack",
      "description": "The second stack."
    },
    {
      "name": "len stack2",
      "type": "int",
      "description": "The number of elements in the second stack."
    }
  ],
  "returns": {
    "type": "string",
    "description": "Print the merged stack in ascending order."
  },
  "constraints": [
    "None"
  ],
  "examples": [
    {
      "title": "Exemple 1",
      "input": {
        "stack1": [1, 3, 5],
        "len stack1": 3,
        "stack2": [2, 4, 6],
        "len stack2": 3
      },
      "output": [1, 2, 3, 4, 5, 6]
    },
    {
      "title": "Exemple 2",
      "input": {
        "stack1": [1, 9, 3],
        "len stack1": 3,
        "stack2": [4, 5, 6],
        "len stack2": 3
      },
      "output": [1, 3, 4, 5, 6, 9]
    },
    {
      "title": "Exemple 3",
      "input": {
        "stack1": [12, 4, 3],
        "len stack1": 3,
        "stack2": [6, 90, 8],
        "len stack2": 3
      },
      "output": [3, 4, 6, 8, 12, 90]
    },
    {
      "title": "Exemple 4",
      "input": {
        "stack1": [1, 2, 3, 6, 8, 12],
        "len stack1": 6,
        "stack2": [1, 2, 3],
        "len stack2": 3
      },
      "output": [1, 1, 2, 2, 3, 3, 6, 8, 12]
    }
  ],
  "file_name": "sort_the_stack.c",
  "function_name": "sort_the_stack",
  "checker": "exact_array",
  "time_limit_ms": 1200,
  "tests": [
    {
      "name": "test1",
      "group": "core",
      "args": [[1, 3, 5], 3, [2, 4, 6], 3],
      "expected": [1, 2, 3, 4, 5, 6]
    },
    {
      "name": "test2",
      "group": "core",
      "args": [[1, 9, 3], 3, [4, 5, 6], 3],
      "expected": [1, 3, 4, 5, 6, 9]
    },
    {
      "name": "test3",
      "group": "core",
      "args": [[12, 4, 3], 3, [6, 90, 8], 3],
      "expected": [3, 4, 6, 8, 12, 90]
    },
    {
      "name": "test4",
      "group": "core",
      "args": [[1, 2, 3, 4], 4, [3, 2, 1], 3],
      "expected": [1, 1, 2, 2, 3, 3, 4]
    }
  ]
}